// ═══════════════════════════════════════════════════════════════════════════
// Firestore Security Rules
// BioSmart Biodigester Monitoring System
// Plateau Central, Burkina Faso
// ═══════════════════════════════════════════════════════════════════════════

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ───────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isValidEmail() {
      return request.auth.token.email != null;
    }

    function hasValidUserShape() {
      return request.resource.data.keys().hasAll(['fullName', 'email', 'phone', 'farmName', 'role']) &&
        request.resource.data.role is string &&
        request.resource.data.email is string;
    }

    // True when the request does not attempt to change the immutable `role`
    // field of an existing document. Prevents privilege escalation.
    function roleUnchanged() {
      return request.resource.data.role == resource.data.role;
    }

    // ─── Users Collection ───────────────────────────────────────────────
    // Users can read/update their own profile. Admins can read all.

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();

      // New accounts may only be created by their own owner and must start
      // with the non-privileged 'user' role.
      allow create: if isAuthenticated() && request.auth.uid == userId &&
        hasValidUserShape() && request.resource.data.role == 'user';

      // Owners may update their own profile but cannot change their role.
      // Only admins may change roles (or any user document).
      allow update: if hasValidUserShape() && (
        (isOwner(userId) && roleUnchanged()) || isAdmin()
      );

      allow delete: if isAdmin();
    }

    // ─── Farms Collection ───────────────────────────────────────────────
    // Users can CRUD their own farms. Admins can access all.

    match /farms/{farmId} {
      allow read: if isAuthenticated() && (
        resource.data.ownerId == request.auth.uid || isAdmin()
      );
      allow create: if isAuthenticated() &&
        request.resource.data.ownerId == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.ownerId == request.auth.uid || isAdmin()
      );
      allow delete: if isAuthenticated() && (
        resource.data.ownerId == request.auth.uid || isAdmin()
      );

      // Subcollections: feeding schedule
      match /feedings/{feedingId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated();
      }
    }

    // ─── Alerts Collection ──────────────────────────────────────────────
    // All authenticated users can read alerts.
    // Only system (ESP32 service account) and admins can create/modify.

    match /alerts/{alertId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // ─── History Collection ─────────────────────────────────────────────
    // Users can read their own history. System can write.

    match /history/{userId}/readings/{readingId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ─── Sensor Health Collection ───────────────────────────────────────
    // Calibration and maintenance records.

    match /sensorHealth/{sensorId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // ─── Config Collection ──────────────────────────────────────────────
    // Threshold configuration and system settings.

    match /config/{configId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ─── Notifications Collection ───────────────────────────────────────
    // Push notification tokens and notification history.

    match /notifications/{userId}/{notificationId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }
  }
}
