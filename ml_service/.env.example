# BioDigit ML Service — Environment Variables
# Copy this file to .env and fill in your values.
#
# IMPORTANT: Use the Supabase SERVICE ROLE KEY (not the anon key).
# Find it in: Supabase Dashboard → Settings → API → service_role key
# This key bypasses Row Level Security, which is required for the
# ML service to write to anomaly_history and alerts tables.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here
